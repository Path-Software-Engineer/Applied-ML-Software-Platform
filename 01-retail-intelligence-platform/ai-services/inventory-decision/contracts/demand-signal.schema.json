{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://retail-intelligence.local/contracts/demand-signal/1.0",
  "title": "Observed Demand Signal",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "signal_type", "signal_unit", "records"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "signal_type": {"const": "observed_daily_average"},
    "signal_unit": {"const": "units_per_day"},
    "records": {
      "type": "array",
      "minItems": 1,
      "x-unique-key": "product_id",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "product_id", "product_name", "signal_type", "signal_value",
          "signal_unit", "period_start", "period_end", "observation_days",
          "observed_units", "source_artifact", "source_sha256"
        ],
        "properties": {
          "product_id": {"type": "string", "minLength": 1},
          "product_name": {"type": "string", "minLength": 1},
          "signal_type": {"const": "observed_daily_average"},
          "signal_value": {"type": "number", "minimum": 0},
          "signal_unit": {"const": "units_per_day"},
          "period_start": {"type": "string", "format": "date"},
          "period_end": {"type": "string", "format": "date"},
          "observation_days": {"type": "integer", "minimum": 1},
          "observed_units": {"type": "integer", "minimum": 0},
          "source_artifact": {"type": "string", "minLength": 1},
          "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
