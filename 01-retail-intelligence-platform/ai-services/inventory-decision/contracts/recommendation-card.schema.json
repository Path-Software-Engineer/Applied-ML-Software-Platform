{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://retail-intelligence.local/contracts/inventory-recommendation-card/1.0",
  "title": "Inventory Recommendation Cards",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "module", "policy_version", "cards"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "module": {"const": "inventory_decision"},
    "policy_version": {"const": "inventory-review-policy/1.0"},
    "cards": {
      "type": "array",
      "minItems": 1,
      "x-unique-key": "card_id",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "card_id", "priority_rank", "product", "risk", "evidence",
          "action", "reason", "limitation", "policy_version"
        ],
        "properties": {
          "card_id": {"type": "string", "pattern": "^inventory-[A-Z0-9_-]+$"},
          "priority_rank": {"type": "integer", "minimum": 1},
          "product": {
            "type": "object",
            "additionalProperties": false,
            "required": ["product_id", "product_name"],
            "properties": {
              "product_id": {"type": "string", "minLength": 1},
              "product_name": {"type": "string", "minLength": 1}
            }
          },
          "risk": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "score", "meaning"],
            "properties": {
              "label": {"enum": ["critical", "high", "watch", "healthy"]},
              "score": {"type": "number", "minimum": 0, "maximum": 100},
              "meaning": {"const": "priority_index_not_probability"}
            }
          },
          "evidence": {"type": "object"},
          "action": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "suggested_quantity_units", "unit"],
            "properties": {
              "code": {"enum": ["replenish_now", "replenish_soon", "review", "monitor"]},
              "suggested_quantity_units": {"type": "integer", "minimum": 0},
              "unit": {"const": "units"}
            }
          },
          "reason": {"type": "string", "minLength": 1},
          "limitation": {"type": "string", "minLength": 1},
          "policy_version": {"const": "inventory-review-policy/1.0"}
        }
      }
    }
  }
}
